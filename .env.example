# Environment Variables Template for Church Management System
# Copy this file to .env and fill in your actual values

# JWT Secret Key for token signing (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your_super_secret_jwt_key_here

# Session Secret Key for FastAPI sessions (CHANGE THIS IN PRODUCTION!)
SESSION_SECRET_KEY=your_super_secret_session_key_here

# Database Configuration
DATABASE_URL=sqlite:///./church.db

# CORS Origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Token Expiration (minutes)
JWT_EXPIRE_MINUTES=20